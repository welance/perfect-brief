# Copy to .env and fill in. All vars are prefixed PB_.

# --- LLM judge & suggestions (leave keys empty to run mock-only) ---
# Direct Anthropic (single model, PB_MODEL):
PB_ANTHROPIC_API_KEY=
PB_MODEL=claude-sonnet-4-6
# OR OpenRouter (wins if both keys are set; enables per-request model choice).
# PB_OPENROUTER_MODELS is the allowlist a request may pick from — exact
# vendor-prefixed OpenRouter slugs, comma-separated; the first is the default.
PB_OPENROUTER_API_KEY=
PB_OPENROUTER_MODELS=anthropic/claude-sonnet-4.5,openai/gpt-4o
PB_LLM_MAX_TOKENS=1500

# --- Redis (verdict cache + rate limit) ---
PB_REDIS_URL=redis://redis:6379/0
PB_CACHE_TTL_SECONDS=86400

# --- Policy ---
# mock = offline keyword engine (instant, deterministic). llm = server-side judge.
PB_DEFAULT_JUDGE=mock
PB_RATE_LIMIT_PER_MINUTE=60
PB_REQUEST_MAX_CHARS=20000
# JSON list; lock this down in production, e.g. ["https://welance.com"]
PB_CORS_ORIGINS=["*"]
