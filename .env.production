# Production env for briefs.welance.com. At deploy time CI wraps this file
# into the tenant's env.yaml (envFileContent); the 1Password operator then
# resolves the placeholder from vaults/DevOps/items/r001-15_env.production.
# Never put a real secret in this file.
PB_ANTHROPIC_API_KEY=INJECTED-FROM-DevOpsVault-BY-1PASSWORD-OPERATOR
PB_MODEL=claude-sonnet-4-6
PB_DEFAULT_JUDGE=mock
PB_REDIS_URL=redis://redis:6379/0
PB_CORS_ORIGINS=["https://welance.com","https://welance.github.io"]
