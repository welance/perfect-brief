# develop env (r001-15.develop.welance.space). At deploy time CI wraps this
# file into the develop tenant's env.yaml; the 1Password operator resolves the
# placeholder from vaults/DevOps/items/r001-15_env.develop (field name =
# PB_OPENROUTER_API_KEY). Mock stays the default judge; the LLM judge and the
# model allowlist light up once the vault item exists. Never a real secret here.
PB_OPENROUTER_API_KEY=INJECTED-FROM-DevOpsVault-BY-1PASSWORD-OPERATOR
PB_OPENROUTER_MODELS=anthropic/claude-sonnet-4.5,openai/gpt-4o
PB_DEFAULT_JUDGE=mock
PB_REDIS_URL=redis://redis:6379/0
